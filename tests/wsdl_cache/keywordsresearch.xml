                        <xsd:element name="Keywords" type="ns:DeduplicateRequestItem"
                                     minOccurs="1" maxOccurs="unbounded" />
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
            <xsd:complexType name="DeduplicateErrorItem">
                <xsd:complexContent>
                    <xsd:extension base="general:ActionResult">
                        <xsd:sequence>
